    <!-- 设置页面标题 -->
    <string name="settings_title">Dou++ 设置</string>

    <!-- 分类标题 -->
    <string name="category_download">下载功能</string>
    <string name="category_enhance">增强功能</string>
    <string name="category_comment">评论区</string>
    <string name="category_storage">存储</string>

    <!-- 下载功能 -->
    <string name="pref_download_video_title">无水印下载视频</string>
    <string name="pref_download_video_summary">在分享面板显示"下载视频"按钮</string>

    <string name="pref_download_music_title">下载音乐 MP3</string>
